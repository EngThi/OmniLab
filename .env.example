# OmniLab runtime
GEMINI_API_KEY=your_api_key_here

PORT=8000

# Optional: exported browser session cookies for authorized search/account sessions.
# The backend also reuses ~/.playwright_data as the persistent Playwright profile.
COOKIE_FILE=/home/ubuntu/arq.json
PLAYWRIGHT_USER_DATA_DIR=/home/ubuntu/.playwright_data

# Optional official web search APIs. DuckDuckGo HTML fallback works without a key.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
BRAVE_SEARCH_API_KEY=

# Optional Perplexity Web MCP CLI. Used first for WEB SEARCH when installed/login is ready.
PWM_COMMAND=/home/ubuntu/.local/bin/pwm
PWM_PYTHON=/home/ubuntu/.local/share/pipx/venvs/perplexity-web-mcp-cli/bin/python
PERPLEXITY_TOKEN_FILE=/home/ubuntu/.config/perplexity-web-mcp/token
PERPLEXITY_SESSION_TURNS=4

# Optional Watchtower automation interval.
WATCH_INTERVAL_SECONDS=45
WATCH_TIMEOUT_SECONDS=12

# Optional proxy rotation file. Format per line: host:port:username:password
SEARCH_PROXY_FILE=/home/ubuntu/webshare_proxies.txt
