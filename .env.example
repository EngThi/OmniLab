# Configurações do OmniLab

# Modo de Demonstração (Mocks de IA e Webcam)
DEMO_MODE=true

# Google Gemini API Key
GEMINI_API_KEY=your_api_key_here

# Configurações de Rede
PORT=8000
SHOW_VISION=false

# ── MODEL CONTEXT PROTOCOL (MCP) ──
# URL do Servidor MCP (Playwright) - Padrão do IDX/Local
# Para rodar amanhã: npx -y @playwright/mcp@latest
MCP_PLAYWRIGHT_URL=http://localhost:3001
