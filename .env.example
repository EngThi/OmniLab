# Configurações do OmniLab

# Modo de Demonstração (Mocks de IA e Webcam)
# true = Funciona sem webcam e sem API Key
# false = Produção (Requer webcam e GEMINI_API_KEY)
DEMO_MODE=true

# Google Gemini API Key (Opcional se DEMO_MODE=true)
GEMINI_API_KEY=your_api_key_here

# Configurações de Rede
PORT=8000
SHOW_VISION=false
